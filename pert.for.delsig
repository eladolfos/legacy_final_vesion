       u_ub=splitsud(1,a_x_a,amu)*apdf(-2,a_x_b,amu)
     >     +splitsud(4,a_x_a,amu)*apdf(-4,a_x_b,amu)

       d_db=splitsud(2,a_x_a,amu)*apdf(-1,a_x_b,amu)
